generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Agent {
  id          String   @id @default(uuid())
  name        String   @unique
  role        String
  model       String   @default("gemini-1.5-flash")
  identity    String?
  soul        String?
  tools       String?  // Stored as JSON string
  status      String   @default("idle") // idle, working, paused, error
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastRun     DateTime?
  totalTasks  Int      @default(0)
  successRate Float    @default(0.0)

  tasks       Task[]
  runs        Run[]
  teamMembers TeamMember[]
}

model Task {
  id          String   @id @default(uuid())
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  teamId      String?
  team        Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  parentTaskId String?
  parentTask  Task?    @relation("SubTasks", fields: [parentTaskId], references: [id])
  subTasks    Task[]   @relation("SubTasks")
  title       String
  description String
  priority    String   @default("medium") // low, medium, high, critical
  status      String   @default("pending") // pending, assigned, in-progress, completed, failed, blocked
  context     String?  // JSON string
  createdBy   String   @default("user") // user, agent, system
  tags        String?  // JSON string
  deadline    DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  runs        Run[]
}

model Team {
  id          String   @id @default(uuid())
  name        String
  description String?
  status      String   @default("active") // active, completed, archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks       Task[]
  members     TeamMember[]
  blackboard  Blackboard?
  decisionLogs DecisionLog[]
}
model TeamMember {
  id          String   @id @default(uuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  role        String   // lead, backend, ui, devops, etc.
  createdAt   DateTime @default(now())
}


model Run {
  id          String   @id @default(uuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  startedAt   DateTime @default(now())
  endedAt     DateTime?
  status      String   @default("running") // running, completed, failed, cancelled
  tokensUsed  Int      @default(0)
  cost        Float    @default(0.0)

  transcripts Transcript[]
}

model Transcript {
  id          String   @id @default(uuid())
  runId       String
  run         Run      @relation(fields: [runId], references: [id], onDelete: Cascade)
  timestamp   DateTime @default(now())
  type        String   // system, assistant, tool, user, error
  content     String
  metadata    String?  // JSON string
}

model Blackboard {
  id          String   @id @default(uuid())
  teamId      String   @unique
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  data        String   // JSON string storing shared variables/datasets
  messages    String   // JSON string of conversation history
  consensus   Boolean  @default(false)
  updatedAt   DateTime @updatedAt
}

model DecisionLog {
  id          String   @id @default(uuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  decision    String
  reason      String?
  timestamp   DateTime @default(now())
}

model Setting {
  key         String   @id
  value       String
  updatedAt   DateTime @updatedAt
}


