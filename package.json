{
  "name": "forgelab",
  "version": "0.1.0",
  "type": "module",
  "description": "ForgeLab - Persistent AI Agent Framework with Memory and Identity",
  "main": "forge",
  "bin": {
    "forge": "./forge"
  },
  "scripts": {
    "dev": "node start.cjs",
    "start": "node start.cjs",
    "start:server": "cd server && npm run dev",
    "start:ui": "cd ui && npm run dev",
    "forge": "node forge.js",
    "migrate": "python scripts/migrate_agents.py --workspace workspace",
    "cleanup": "python scripts/cleanup_old_files.py --workspace workspace"
  },
  "keywords": [
    "ai",
    "agent",
    "forge",
    "paperclip",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^0.2.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "open": "^10.2.0"
  }
}
