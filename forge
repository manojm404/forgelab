#!/usr/bin/env node

/**
 * ForgeLab CLI Entry Point
 *
 * This script is called by Paperclip to execute ForgeLab agents.
 * It receives context via environment variables and agent configuration.
 */

import { spawn } from 'node:child_process';
import { readFileSync, existsSync } from 'node:fs';
import fs from 'node:fs';
import { join, dirname } from 'node:path';
import { fileURLToPath } from 'node:url';
import { GoogleGenerativeAI } from '@google/generative-ai';

const __dirname = dirname(fileURLToPath(import.meta.url));

// Parse command line arguments
const args = process.argv.slice(2);
const config = {
  workspacePath: null,
  agentName: null,
  wakeReason: null,
  task: null,
  help: false,
};

// Parse arguments
for (let i = 0; i < args.length; i++) {
  switch (args[i]) {
    case '--workspace':
    case '-w':
      config.workspacePath = args[++i];
      break;
    case '--agent':
    case '-a':
      config.agentName = args[++i];
      break;
    case '--wake-reason':
      config.wakeReason = args[++i];
      break;
    case '--task':
    case '-t':
      config.task = args[++i];
      break;
    case '--help':
    case '-h':
      config.help = true;
      break;
  }
}

// Show help
if (config.help) {
  console.log(`
ForgeLab CLI - AI Agent Runtime

Usage: forge [options]

Options:
  -w, --workspace <path>    Path to ForgeLab workspace (default: current dir)
  -a, --agent <name>        Agent name to execute
  -t, --task <id>           Task ID from Paperclip
  --wake-reason <reason>    Wake reason (heartbeat, task, manual)
  -h, --help                Show this help message

Environment Variables:
  FORGELAB_RUN_ID           Paperclip run identifier
  FORGELAB_AGENT_ID         Paperclip agent identifier
  FORGELAB_COMPANY_ID       Paperclip company identifier
  FORGELAB_PAPERCLIP_CONTEXT JSON string with full context
  FORGELAB_LOG_LEVEL        Log level (debug/info/warn/error)
  GEMINI_API_KEY            Gemini API key (required)

Examples:
  forge --agent software-architect --task task_123
  forge -w /path/to/workspace -a content-creator
`);
  process.exit(0);
}

// Resolve workspace path
const workspacePath = config.workspacePath || process.cwd();

// Load environment from .env file if it exists
const envPath = join(workspacePath, '..', '.env');
if (existsSync(envPath)) {
  const envContent = readFileSync(envPath, 'utf-8');
  envContent.split('\n').forEach(line => {
    const [key, ...valueParts] = line.split('=');
    if (key && valueParts.length > 0) {
      const value = valueParts.join('=').trim();
      if (value && !process.env[key.trim()]) {
        process.env[key.trim()] = value;
      }
    }
  });
}

// Validate required environment
const isMockMode = !process.env.GEMINI_API_KEY || process.env.GEMINI_API_KEY === 'mock' || process.env.FORGELAB_MOCK === 'true';

if (!process.env.GEMINI_API_KEY && !isMockMode) {
  console.error('[forgelab:error] GEMINI_API_KEY is required but not set');
  console.error('[forgelab:error] Set it in .env file or as environment variable');
  process.exit(1);
}

// Get Paperclip context
let paperclipContext = null;
if (process.env.FORGELAB_PAPERCLIP_CONTEXT) {
  try {
    paperclipContext = JSON.parse(process.env.FORGELAB_PAPERCLIP_CONTEXT);
    console.log(`[forgelab] Paperclip context received:`);
    console.log(`  - Run ID: ${paperclipContext.paperclip?.runId || 'N/A'}`);
    console.log(`  - Company: ${paperclipContext.paperclip?.company?.id || 'N/A'}`);
    console.log(`  - Agent: ${paperclipContext.paperclip?.agent?.name || 'N/A'}`);
    console.log(`  - Task: ${paperclipContext.paperclip?.task?.key || config.task || 'N/A'}`);
  } catch (e) {
    console.log(`[forgelab] Could not parse Paperclip context: ${e.message}`);
  }
}

// Determine which agent to run
const agentName = config.agentName || paperclipContext?.paperclip?.agent?.name;

if (!agentName) {
  console.error('[forgelab:error] No agent specified. Use --agent <name> or set agent name in Paperclip.');
  process.exit(1);
}

if (!isMockMode) {
  console.log(`[forgelab] Starting agent: ${agentName}`);
  console.log(`[forgelab] Workspace: ${workspacePath}`);
  console.log(`[forgelab] Wake reason: ${config.wakeReason || 'manual'}`);
}

// Path to the agent workspace
const agentWorkspace = join(workspacePath, 'agents', agentName);

if (!existsSync(agentWorkspace)) {
  console.error(`[forgelab:error] Agent workspace not found: ${agentWorkspace}`);
  process.exit(1);
}

// Read agent configuration
const agentsMdPath = join(agentWorkspace, 'AGENTS.md');
const identityPath = join(agentWorkspace, 'IDENTITY.md');
const soulPath = join(agentWorkspace, 'SOUL.md');
const toolsPath = join(agentWorkspace, 'TOOLS.md');

if (!isMockMode) {
  console.log(`[forgelab] Loading agent configuration from: ${agentWorkspace}`);
}

// Build the agent prompt based on Paperclip task
let systemPrompt = '';

if (existsSync(identityPath)) {
  const identity = readFileSync(identityPath, 'utf-8');
  systemPrompt += `# Identity\n${identity}\n\n`;
}

if (existsSync(soulPath)) {
  const soul = readFileSync(soulPath, 'utf-8');
  systemPrompt += `# Core Principles\n${soul}\n\n`;
}

if (existsSync(agentsMdPath)) {
  const agents = readFileSync(agentsMdPath, 'utf-8');
  systemPrompt += `# Workspace Guidelines\n${agents}\n\n`;
}

// Add Paperclip task context
if (paperclipContext) {
  systemPrompt += `# Current Task (from Paperclip)\n`;
  systemPrompt += `You are working as part of a company managed by Paperclip.\n`;
  systemPrompt += `Your role: ${paperclipContext.paperclip?.agent?.name || agentName}\n`;
  systemPrompt += `Company ID: ${paperclipContext.paperclip?.company?.id || 'N/A'}\n`;
  systemPrompt += `Task: ${paperclipContext.paperclip?.task?.key || config.task || 'No specific task assigned'}\n\n`;
}

// Add wake reason context
if (config.wakeReason) {
  systemPrompt += `# Wake Context\n`;
  systemPrompt += `You were awakened because: ${config.wakeReason}\n\n`;
}

// Log system prompt (truncated for brevity)
const logLevel = process.env.FORGELAB_LOG_LEVEL || 'info';
if (logLevel === 'debug') {
  console.log(`[forgelab:debug] System prompt (${systemPrompt.length} chars):`);
  console.log(systemPrompt.substring(0, 500) + '...');
}

if (!isMockMode) {
  console.log(`[forgelab] Initializing Gemini API...`);
}

// Tool definitions for autonomous collaboration
const tools = [
  {
    functionDeclarations: [
      {
        name: "post_to_blackboard",
        description: "Post a message, decision, or data to the team's shared blackboard for other agents to see.",
        parameters: {
          type: "object",
          properties: {
            content: { type: "string", description: "The message or data to post" },
            type: { 
              type: "string", 
              enum: ["proposal", "review", "handoff", "decision"],
              description: "The category of the blackboard post" 
            }
          },
          required: ["content"]
        }
      },
      {
        name: "create_subtask",
        description: "Decompose a larger goal into a specific sub-task and assign it to another agent.",
        parameters: {
          type: "object",
          properties: {
            title: { type: "string", description: "Short, actionable title of the task" },
            description: { type: "string", description: "Detailed instructions and context for the task" },
            agentIdOrRole: { type: "string", description: "The name, ID, or role of the agent to assign this to (e.g., 'Frontend Developer')" }
          },
          required: ["title", "description", "agentIdOrRole"]
        }
      },
      {
        name: "request_human_approval",
        description: "Pause execution and request manual approval/feedback from a human operator for a critical decision.",
        parameters: {
          type: "object",
          properties: {
            reason: { type: "string", description: "The specific reason or choice requiring human intervention" }
          },
          required: ["reason"]
        }
      },
      {
        name: "read_file",
        description: "Read the contents of a file in the workspace.",
        parameters: {
          type: "object",
          properties: {
            path: { type: "string", description: "Relative path to the file from the workspace root" }
          },
          required: ["path"]
        }
      },
      {
        name: "list_directory",
        description: "List the files and folders in a directory.",
        parameters: {
          type: "object",
          properties: {
            path: { type: "string", description: "Relative path to the directory from the workspace root" }
          },
          required: ["path"]
        }
      },
      {
        name: "write_file",
        description: "Write content to a file in the workspace.",
        parameters: {
          type: "object",
          properties: {
            path: { type: "string", description: "Relative path to the file from the workspace root" },
            content: { type: "string", description: "The content to write" }
          },
          required: ["path", "content"]
        }
      }
    ]
  }
];

// Create the main execution function
async function runAgent() {
  try {
    if (isMockMode) {
      // Use a simple file-based session tracker to distinguish first vs subsequent calls
      const sessionFile = join(process.env.FORGELAB_WORKSPACE || workspacePath, 'agents', agentName, '.session_active');
      const isFirstTurn = !existsSync(sessionFile);
      
      // Simulate thinking time
      await new Promise(resolve => setTimeout(resolve, 1000));

      let mockResponse = "";
      
      if (isFirstTurn) {
        // Create session marker
        try { fs.writeFileSync(sessionFile, Date.now().toString()); } catch(e) {}
        
        mockResponse = `## Neural Handshake: ${agentName} Active\n\n` +
                        `Hello! I am the **${agentName}**. I've been initialized with a specialized **Identity** and **Soul** to handle your project architecture and execution.\n\n` +
                        `I'm ready to dive into your workspace and get to work. What's our first objective?`;
      } else {
        mockResponse = `## System Notification\n\n` +
                        `I am currently operating in **Simulation Mode**. To unlock my full cognitive potential and allow me to execute real-world logic, please **connect your Gemini API Key** in the System Settings.\n\n` +
                        `Give me life, and I will build wonders for you.`;
      }

      console.log(`\n${mockResponse}\n`);
      console.log(`[forgelab] Agent execution completed successfully (MOCK)`);
      process.exit(0);
      return;
    }

    const genAI = new GoogleGenerativeAI(process.env.GEMINI_API_KEY);

    // Use standard SDK pattern with tools
    const model = genAI.getGenerativeModel({
      model: 'gemini-1.5-flash',
      tools: tools
    }, { apiVersion: 'v1' });

    // Build the user message based on wake reason
    let userMessage = '';
    if (config.wakeReason === 'heartbeat') {
      userMessage = 'Heartbeat check. Review your HEARTBEAT.md if it exists. Report status or items requiring attention.';
    } else if (config.task || paperclipContext?.paperclip?.task?.key) {
      userMessage = `Execute your assigned task: ${config.task || paperclipContext?.paperclip?.task?.key}. Use your tools to collaborate if needed.`;
    } else {
      userMessage = 'Awaiting instructions. Review your workspace and report your current status.';
    }

    if (!isMockMode) {
      console.log(`[forgelab] Sending request to Gemini...`);
    }

    const prompt = `${systemPrompt}\n\n# Current Request\n${userMessage}`;

    try {
      // Start a chat to handle tool calls
      const chat = model.startChat();
      let result = await chat.sendMessage(prompt);
      let response = await result.response;

      // Loop to handle tool calls
      let rounds = 0;
      const MAX_ROUNDS = 10;

      while (rounds < MAX_ROUNDS) {
        const calls = response.functionCalls();
        if (!calls || calls.length === 0) break;

        const toolResponses = [];

        for (const call of calls) {
          // Output structured tool call for the runner to intercept (for logging/UI sync)
          console.log(`[FORGELAB_TOOL_CALL] ${JSON.stringify(call)}`);

          let toolResult;
          try {
            switch (call.name) {
              case 'read_file':
                const fullReadPath = join(workspacePath, call.args.path);
                if (existsSync(fullReadPath)) {
                  toolResult = readFileSync(fullReadPath, 'utf8');
                } else {
                  toolResult = `Error: File not found at ${call.args.path}`;
                }
                break;
              case 'list_directory':
                const fullListPath = join(workspacePath, call.args.path);
                if (existsSync(fullListPath)) {
                  toolResult = fs.readdirSync(fullListPath).join('\n');
                } else {
                  toolResult = `Error: Directory not found at ${call.args.path}`;
                }
                break;
              case 'write_file':
                const fullWritePath = join(workspacePath, call.args.path);
                const dir = dirname(fullWritePath);
                if (!existsSync(dir)) fs.mkdirSync(dir, { recursive: true });
                fs.writeFileSync(fullWritePath, call.args.content);
                toolResult = `Successfully wrote to ${call.args.path}`;
                break;
              default:
                // For other tools (blackboard, subtasks), we let the runner handle them
                // but we need to provide a dummy response to the model to continue the conversation
                toolResult = `Acknowledged: ${call.name} executed.`;
                break;
            }
          } catch (e) {
            toolResult = `Error executing ${call.name}: ${e.message}`;
          }

          toolResponses.push({
            functionResponse: {
              name: call.name,
              response: { result: toolResult }
            }
          });
        }

        // Send tool results back to the model
        result = await chat.sendMessage(toolResponses);
        response = await result.response;
        rounds++;
      }

      const responseText = response.text();
      console.log(`\n## Response\n${responseText}\n`);
      console.log(`[forgelab] Agent execution completed successfully`);

      if (response.usageMetadata) {
        console.log(`[forgelab] Tokens: ${response.usageMetadata.promptTokenCount} in, ${response.usageMetadata.candidatesTokenCount} out`);
      }
    } catch (apiError) {
      console.error(`[forgelab:error] API Error: ${apiError.message}`);
      process.exit(1);
    }

    process.exit(0);
  } catch (error) {
    console.error(`[forgelab:error] Agent execution failed: ${error.message}`);
    if (logLevel === 'debug') {
      console.error(error.stack);
    }
    process.exit(1);
  }
}

// Run the agent
runAgent();
